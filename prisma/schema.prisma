generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  EMPLOYEE
  MANAGER
  ADMIN
}

enum UoMType {
  NUMERIC_MIN
  NUMERIC_MAX
  TIMELINE
  ZERO
}

enum GoalStatus {
  DRAFT
  SUBMITTED
  APPROVED
  LOCKED
  RETURNED
}

enum AchievementStatus {
  NOT_STARTED
  ON_TRACK
  COMPLETED
}

enum CyclePhase {
  GOAL_SETTING
  Q1
  Q2
  Q3
  Q4
}

enum EscalationStatus {
  OPEN
  RESOLVED
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String
  role          Role
  departmentId  String?
  managerId     String?
  mustChangePassword Boolean @default(false)
  authProvider  String   @default("LOCAL") // "LOCAL" | "AZURE_AD"
  azureOid      String?  @unique           // Azure AD object id (oid claim) — proves same Azure identity
  lastSsoLoginAt DateTime?
  createdAt     DateTime @default(now())

  department    Department?  @relation(fields: [departmentId], references: [id])
  manager       User?        @relation("Reports", fields: [managerId], references: [id])
  reports       User[]       @relation("Reports")
  goalSheets    GoalSheet[]
  checkIns      CheckIn[]
  auditLogs     AuditLog[]
  escalations   Escalation[]
}

model Department {
  id    String @id @default(cuid())
  name  String @unique
  users User[]
}

model GoalCycle {
  id          String     @id @default(cuid())
  phase       CyclePhase
  year        Int
  openDate    DateTime
  closeDate   DateTime
  isOverride  Boolean    @default(false)
  createdAt   DateTime   @default(now())

  goalSheets  GoalSheet[]
  achievements Achievement[]
}

model GoalSheet {
  id          String     @id @default(cuid())
  userId      String
  cycleId     String
  status      GoalStatus @default(DRAFT)
  submittedAt DateTime?
  approvedAt  DateTime?
  lockedAt    DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user        User        @relation(fields: [userId], references: [id])
  cycle       GoalCycle   @relation(fields: [cycleId], references: [id])
  goals       Goal[]
  checkIns    CheckIn[]
}

model Goal {
  id             String  @id @default(cuid())
  goalSheetId    String
  thrustArea     String
  title          String
  description    String
  uomType        UoMType
  target         Float
  deadline       DateTime?
  weightage      Int
  isShared       Boolean @default(false)
  sharedFromId   String?
  isPrimaryOwner Boolean @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  goalSheet      GoalSheet    @relation(fields: [goalSheetId], references: [id])
  sharedFrom     Goal?        @relation("SharedGoals", fields: [sharedFromId], references: [id])
  sharedCopies   Goal[]       @relation("SharedGoals")
  achievements   Achievement[]
}

model Achievement {
  id          String            @id @default(cuid())
  goalId      String
  cycleId     String
  actual      Float?
  actualDate  DateTime?
  status      AchievementStatus @default(NOT_STARTED)
  score       Float?
  updatedAt   DateTime          @updatedAt

  goal        Goal      @relation(fields: [goalId], references: [id])
  cycle       GoalCycle @relation(fields: [cycleId], references: [id])

  @@unique([goalId, cycleId])
}

model CheckIn {
  id          String   @id @default(cuid())
  goalSheetId String
  managerId   String
  cycleId     String
  comment     String
  createdAt   DateTime @default(now())

  goalSheet   GoalSheet @relation(fields: [goalSheetId], references: [id])
  manager     User      @relation(fields: [managerId], references: [id])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  goalId      String?
  goalSheetId String?
  action      String
  fieldName   String?
  oldValue    String?
  newValue    String?
  createdAt   DateTime @default(now())

  user        User @relation(fields: [userId], references: [id])
}

model EscalationRule {
  id            String @id @default(cuid())
  eventType     String
  triggerAfterDays Int
  notifyRole    Role
  isActive      Boolean @default(true)
}

model Escalation {
  id          String           @id @default(cuid())
  userId      String
  ruleId      String?
  reason      String
  status      EscalationStatus @default(OPEN)
  resolvedAt  DateTime?
  createdAt   DateTime         @default(now())

  user        User @relation(fields: [userId], references: [id])
}
