# ═══════════════════════════════════════════════════════════════════════
# GoalFlow — environment variables template
# Copy to `.env` and fill in real values. `.env` is gitignored.
# Vite reads VITE_* keys from this same file via vite.config.ts (envDir).
# ═══════════════════════════════════════════════════════════════════════

# ─── Supabase Postgres ─────────────────────────────────────────────────
# Pooled connection (PgBouncer, port 6543) — used by Prisma at runtime
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection (port 5432) — used by `prisma migrate` / `prisma db push`
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# ─── Auth (JWT) ────────────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# ─── Server ────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV="development"
FRONTEND_URL="http://localhost:5173"
APP_BASE_URL="http://localhost:5173"

# ─── Admin override ────────────────────────────────────────────────────
# This email is auto-promoted to ADMIN on local signup and Microsoft SSO.
ADMIN_OVERRIDE_EMAIL=""

# ─── Azure AD / Microsoft Entra ID — server (confidential client) ──────
AZURE_TENANT_ID=""
AZURE_CLIENT_ID=""
AZURE_CLIENT_SECRET=""
AZURE_REDIRECT_URI="http://localhost:5173"

# Group object IDs → role mapping
AZURE_GROUP_ADMIN=""
AZURE_GROUP_MANAGER=""
AZURE_GROUP_EMPLOYEE=""

# Auto-sync Azure AD users on API startup. Keep "false" until admin
# consent for User.Read.All / Directory.Read.All is granted in Azure portal.
AZURE_AUTO_SYNC="false"

# ─── Azure AD — web (MSAL SPA / public client) ─────────────────────────
# Typically same app registration as server, with an SPA redirect URI.
VITE_AZURE_CLIENT_ID=""
VITE_AZURE_TENANT_ID=""
VITE_AZURE_REDIRECT_URI="http://localhost:5173"

# ─── Vite frontend → API base URL ──────────────────────────────────────
VITE_API_URL="http://localhost:4000/api"

# ─── Email (SendGrid) — optional ───────────────────────────────────────
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL=""

# ─── Microsoft Teams incoming webhook — optional ───────────────────────
TEAMS_WEBHOOK_URL=""
