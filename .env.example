# ═══ GoalFlow Environment Configuration ═══
# Copy this file to .env and fill in your values

# ═══ DATABASE (Supabase PostgreSQL) ═══
# Pooled connection - for app runtime
DATABASE_URL="postgresql://postgres.xxxxx:YOUR_PASSWORD@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection - for migrations only
DIRECT_URL="postgresql://postgres.xxxxx:YOUR_PASSWORD@aws-1-ap-south-1.pooler.supabase.com:5432/postgres"

# ═══ AUTHENTICATION ═══
JWT_SECRET="your-secret-key-change-this"
JWT_EXPIRES_IN="7d"

# ═══ SERVER ═══
PORT=4000
FRONTEND_URL="http://localhost:5173"
APP_BASE_URL="http://localhost:5173"
NODE_ENV="development"

# ═══ AZURE AD / MICROSOFT ENTRA ID SSO (Optional) ═══
# SSO button auto-appears on login page when CLIENT_ID + TENANT_ID are set
# 1. Create App Registration at https://portal.azure.com → Entra ID → App registrations
# 2. Set redirect URI to http://localhost:5173 (dev) and your Vercel URL (prod)
# 3. Add API permissions: User.Read, User.ReadBasic.All, Directory.Read.All
AZURE_CLIENT_ID=""
AZURE_CLIENT_SECRET=""
AZURE_TENANT_ID=""
AZURE_REDIRECT_URI="http://localhost:5173"

# Security Group Object IDs (Entra ID → Groups → copy Object ID)
# Create groups: GoalFlow-Admins, GoalFlow-Managers, GoalFlow-Employees
AZURE_GROUP_ADMIN=""
AZURE_GROUP_MANAGER=""
AZURE_GROUP_EMPLOYEE=""

# ═══ EMAIL NOTIFICATIONS (Optional) ═══
# Sign up at https://sendgrid.com → Settings → API Keys
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="noreply@goalflow.demo"

# ═══ TEAMS NOTIFICATIONS (Optional) ═══
# Teams channel → ... → Connectors → Incoming Webhook → copy URL
TEAMS_WEBHOOK_URL=""

# ═══ FRONTEND (Vite - prefix with VITE_) ═══
# These go in Vercel Environment Variables for production
# VITE_API_URL=https://your-railway-api.up.railway.app/api
# VITE_AZURE_CLIENT_ID=same-as-AZURE_CLIENT_ID
# VITE_AZURE_TENANT_ID=same-as-AZURE_TENANT_ID
# VITE_AZURE_REDIRECT_URI=https://your-vercel-app.vercel.app
